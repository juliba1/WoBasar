@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout Style="min-height: 100vh">

    <!-- ══ TOPBAR ══ -->
    <MudAppBar Elevation="0" Color="Color.Surface" Dense="true"
               Style="border-bottom: 0.5px solid var(--mud-palette-divider); height: 56px;">

        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           OnClick="ToggleDrawer"
                           Color="Color.Inherit"
                           Class="mt-2"/>

        <!-- Logo -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="padding-left: 24px" Class="mt-2">
            <div class="wo-brand-icon">
                <MudIcon Icon="@Icons.Material.Filled.Storefront"
                         Style="color: white; font-size: 16px;" />
            </div>
            <MudText Typo="Typo.h6"
                     Style="font-weight: 700; font-size: 16px; letter-spacing: -0.3px;"
                    Color="Color.Primary">
                WoBasar
            </MudText>
        </MudStack>

        <!-- Desktop Nav Links -->
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudStack Row="true" Spacing="0" Class="ml-4 mt-2">
                <MudButton Href="/" Color="Color.Primary" Variant="Variant.Text"
                           Style="font-size: 13px; font-weight: 400; min-width: 0; padding: 6px 10px; border-radius: 6px;">
                    Entdecken
                </MudButton>
                <MudButton Href="/meine-anzeigen" Color="Color.Default" Variant="Variant.Text"
                           Style="font-size: 13px; font-weight: 400; min-width: 0; padding: 6px 10px; border-radius: 6px;">
                    Meine Anzeigen
                </MudButton>
            </MudStack>
        </MudHidden>

        <MudSpacer />

        <!-- Suchleiste -->
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudTextField @bind-Value="_searchText"
                          Placeholder="Bücher, Laptop, WG-Zimmer..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="width: 100%; border-radius: 40px;"
                          Class="mr-3 mt-3" />
        </MudHidden>

        <MudSpacer />

        <!-- Anzeige erstellen -->
        <MudButton Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Add"
                   Color="Color.Primary"
                   Style="font-size: 13px; font-weight: 500; border-radius: 8px; text-transform: none;"
                   Class="mr-2 mt-2">
            Anzeige
        </MudButton>

        <!-- Nachrichten -->
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudButton Variant="Variant.Outlined" Class="mt-2"
                       Style="border: 0.5px solid var(--mud-palette-divider); font-size: 13px; border-radius: 8px; text-transform: none; margin-right: 8px;">
                Nachrichten
            </MudButton>
        </MudHidden>

        <!-- Dark mode toggler -->
        <MudIconButton Icon="@(_isDarkMode? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)"
                       OnClick="ToggleDarkMode"
                       Color="Color.Inherit"
                       Class="mt-2 mr-2" />

        <!-- Avatar / Profilmenü -->
        <MudMenu Class="mt-2">
            <ActivatorContent>
                <div @onclick="@context.ToggleAsync" style="cursor: pointer">
                    <div class="wo-avatar">LS</div>
                </div>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Href="/profil" Icon="@Icons.Material.Filled.Person">
                    Mein Profil
                </MudMenuItem>
                <MudMenuItem Href="/nachrichten" Icon="@Icons.Material.Filled.Message">
                    Nachrichten
                </MudMenuItem>
                <MudMenuItem Href="/favoriten" Icon="@Icons.Material.Filled.FavoriteBorder">
                    Merkliste
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">
                    Abmelden
                </MudMenuItem>
            </ChildContent>
        </MudMenu>

        <!-- Mobile Drawer Toggle -->
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           OnClick="ToggleDrawer"
                           Color="Color.Inherit" />
        </MudHidden>

    </MudAppBar>

    <!-- ══ SIDEBAR ══ -->
    <MudDrawer @bind-Open="_drawerOpen"
               Variant="@DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md"
               Elevation="0"
               Style="border-right: 0.5px solid var(--mud-palette-divider); z-index: 1;">

        <MudNavMenu Class="pa-2" Style="display: flex; flex-direction: column; gap: 5px; padding-top: 16px;">

            <!-- Entdecken -->
            <div>
                <MudText Class="wo-sidebar-label mb-1">Entdecken</MudText>
                <MudNavLink Href="/"
                            Icon="@Icons.Material.Filled.GridView"
                            Match="NavLinkMatch.All"
                            Style="font-size: 13px; border-radius: 8px;">
                    Alle Anzeigen
                </MudNavLink>
                <MudNavLink Href="/empfohlen"
                            Icon="@Icons.Material.Filled.Star"
                            Style="font-size: 13px; border-radius: 8px;">
                    Empfohlen
                </MudNavLink>
                <MudNavLink Href="/favoriten"
                            Icon="@Icons.Material.Filled.FavoriteBorder"
                            Style="font-size: 13px; border-radius: 8px;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width: 100%;">
                        <span>Merkliste</span>
                        <MudBadge Content="3" Color="Color.Primary" />
                    </MudStack>
                </MudNavLink>
            </div>

            <!-- Kategorien -->
            <div>
                <MudText Class="wo-sidebar-label mb-1">Kategorien</MudText>
                <MudNavLink Href="/kategorie/buecher"
                            Icon="@Icons.Material.Filled.MenuBook"
                            Style="font-size: 13px; border-radius: 8px;">
                    Bücher &amp; Skripte
                </MudNavLink>
                <MudNavLink Href="/kategorie/elektronik"
                            Icon="@Icons.Material.Filled.Laptop"
                            Style="font-size: 13px; border-radius: 8px;">
                    Elektronik
                </MudNavLink>
                <MudNavLink Href="/kategorie/wohnen"
                            Icon="@Icons.Material.Filled.Home"
                            Style="font-size: 13px; border-radius: 8px;">
                    WG &amp; Wohnen
                </MudNavLink>
                <MudNavLink Href="/kategorie/nachhilfe"
                            Icon="@Icons.Material.Filled.School"
                            Style="font-size: 13px; border-radius: 8px;">
                    Nachhilfe
                </MudNavLink>
                <MudNavLink Href="/kategorie/sport"
                            Icon="@Icons.Material.Filled.SportsBasketball"
                            Style="font-size: 13px; border-radius: 8px;">
                    Sport &amp; Freizeit
                </MudNavLink>
                <MudNavLink Href="/kategorie/sonstiges"
                            Icon="@Icons.Material.Filled.MoreHoriz"
                            Style="font-size: 13px; border-radius: 8px;">
                    Sonstiges
                </MudNavLink>
            </div>

            <!-- Konto -->
            <div>
                <MudText Class="wo-sidebar-label mb-1">Konto</MudText>
                <MudNavLink Href="/profil"
                            Icon="@Icons.Material.Filled.Person"
                            Style="font-size: 13px; border-radius: 8px;">
                    Mein Profil
                </MudNavLink>
                <MudNavLink Href="/nachrichten"
                            Icon="@Icons.Material.Filled.Message"
                            Style="font-size: 13px; border-radius: 8px;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width: 100%;">
                        <span>Nachrichten</span>
                        <MudBadge Content="2" Color="Color.Primary" />
                    </MudStack>
                </MudNavLink>
            </div>

        </MudNavMenu>

    </MudDrawer>

    <!-- ══ MAIN CONTENT ══ -->
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6 px-4">
            @Body
        </MudContainer>
    </MudMainContent>

    <!-- ══ FOOTER ══ -->
    <MudPaper Elevation="0"
              Style="border-top: 0.5px solid var(--mud-palette-divider); padding: 12px 24px; z-index: 1000;">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                © 2026 WoBasar – Studenten-Marktplatz Karlsruhe
            </MudText>
            <MudStack Row="true" Spacing="3">
                <MudLink Href="/impressum" Typo="Typo.caption" Color="Color.Inherit">Impressum</MudLink>
                <MudLink Href="/datenschutz" Typo="Typo.caption" Color="Color.Inherit">Datenschutz</MudLink>
                <MudLink Href="/hilfe" Typo="Typo.caption" Color="Color.Inherit">Hilfe</MudLink>
                <MudLink Href="/feedback" Typo="Typo.caption" Color="Color.Inherit">Feedback</MudLink>
            </MudStack>
        </MudStack>
    </MudPaper>

</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string _searchText = string.Empty;
	private bool _isDarkMode = false;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
    }

    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#4F46E5",                // Indigo (Hauptfarbe / Buttons / Akzente)
            PrimaryContrastText = "#FFFFFF",    // Weiß (Text auf Primary Buttons)

            AppbarBackground = "#FFFFFF",       // Weiß (Topbar Hintergrund)
            AppbarText = "#111111",             // Fast Schwarz (Topbar Text)

            Background = "#F7F7FB",             // Sehr helles Grau-Blau (Seitenhintergrund)
            BackgroundGray = "#F0F0F5",         // Helles Grau (sekundäre Flächen)

            Surface = "#FFFFFF",                // Weiß (Cards, Container)
            DrawerBackground = "#FFFFFF",       // Weiß (Sidebar)

            TextPrimary = "#111111",            // Fast Schwarz (Haupttext)
            TextSecondary = "#555555",          // Dunkelgrau (sekundärer Text)

            Divider = "rgba(0,0,0,0.08)"      // Leichte schwarze Linie (Divider)
        },

        PaletteDark = new PaletteDark()
        {
            Primary = "#6366F1",                // Helleres Indigo (Dark Mode Akzentfarbe)

            Background = "#0F172A",             // Sehr dunkles Blau (Seitenhintergrund)
            Surface = "#1F2937",                // Dunkles Grau-Blau (Cards, Flächen)

            AppbarBackground = "#111827",       // Gleich wie Surface (Topbar)
            DrawerBackground = "#111827",       // Gleich wie Surface (Sidebar)

            TextPrimary = "#E5E7EB",            // Hellgrau (Haupttext)
            TextSecondary = "#9CA3AF",          // Mittleres Grau (sekundärer Text)

            Divider = "rgba(255,255,255,0.08)" // Leichte weiße Linie (Divider im Dark Mode)
        }
    };
}
