@page "/"
@using MudBlazor

<PageTitle>WoBasar – Entdecken</PageTitle>

<div class="wo-hero mb-6">
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudText Typo="Typo.h5" Style="font-weight: 700; letter-spacing: -0.3px; margin-bottom: 6px;">
                Hallo Leon 👋
            </MudText>
            <MudText Style="font-size: 13px; opacity: .8;">
                Finde Deals von Studenten für Studenten an deiner Uni
            </MudText>
            <MudStack Row="true" Spacing="2" Class="mt-3" Style="flex-wrap: wrap;">
                <span class="wo-hero-pill">📚 Prüfungszeit</span>
                <span class="wo-hero-pill">💻 Neue Laptops</span>
                <span class="wo-hero-pill">🏠 WG-Suche</span>
                <span class="wo-hero-pill">⚽ Sportausrüstung</span>
            </MudStack>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudStack AlignItems="AlignItems.End" Justify="Justify.Center" Style="height: 100%;">
                <div style="text-align: right;">
                    <div style="font-size: 28px; font-weight: 700; line-height: 1;">847</div>
                    <div style="font-size: 11px; opacity: .65; margin-top: 2px;">aktive Anzeigen</div>
                </div>
                <div style="text-align: right; margin-top: 8px;">
                    <div style="font-size: 20px; font-weight: 700; line-height: 1;">KIT</div>
                    <div style="font-size: 11px; opacity: .65; margin-top: 2px;">Karlsruhe</div>
                </div>
            </MudStack>
        </MudItem>
    </MudGrid>
</div>

<!-- ══ KATEGORIEN ══ -->
<MudText Typo="Typo.h6" Style="font-weight: 600; font-size: 16px; letter-spacing: -0.2px; margin-bottom: 12px;">
    Kategorien
</MudText>
<MudGrid Class="mb-6">
    @foreach (var cat in _categories)
    {
        <MudItem xs="4" sm="3" md="2">
            <div class="wo-cat-card" @onclick="() => FilterByCategory(cat.Key)">
                <div class="wo-cat-emoji">@cat.Emoji</div>
                <div class="wo-cat-label mt-2">@cat.Label</div>
                <div class="wo-cat-count">@cat.Count Anzeigen</div>
            </div>
        </MudItem>
    }
</MudGrid>

<!-- ══ FILTER + LISTINGS ══ -->
<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4" Style="flex-wrap: wrap;">
    <MudText Typo="Typo.h6" Style="font-weight: 600; font-size: 16px; letter-spacing: -0.2px; flex: 1;">
        Aktuelle Anzeigen
    </MudText>
    @foreach (var f in _filters)
    {
        <span class="wo-filter-chip @(f == _activeFilter ? "active" : "")"
              @onclick="() => SetFilter(f)">
            @f
        </span>
    }
    <MudSelect T="string" @bind-Value="_sortBy" Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense"
               Style="max-width: 160px; font-size: 12px;">
        <MudSelectItem Value="@("Neueste zuerst")" />
        <MudSelectItem Value="@("Preis ↑")" />
        <MudSelectItem Value="@("Preis ↓")" />
    </MudSelect>
</MudStack>

<MudGrid>
    @foreach (var listing in FilteredListings)
    {
        <MudItem xs="12" sm="6" md="4" lg="3">
            <div class="wo-card">
                <!-- Thumbnail -->
                <div class="wo-card-thumb @listing.ThumbClass">@listing.Emoji</div>

                <!-- Badge -->
                @if (!string.IsNullOrEmpty(listing.Badge))
                {
                    <div class="wo-card-badge @listing.BadgeClass">@listing.Badge</div>
                }

                <!-- Fav Icon -->
                <div class="wo-card-fav">
                    <MudIcon Icon="@(listing.Saved? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                             Style="@(listing.Saved ? "color: #E24B4A; font-size: 13px;" : "color: #aaa; font-size: 13px;")"
                             @onclick="() => ToggleSaved(listing)" />
                </div>

                <!-- Body -->
                <div class="wo-card-body">
                    <div class="wo-card-cat">@listing.Category</div>
                    <div class="wo-card-title">@listing.Title</div>
                    <div class="wo-card-price">
                        @listing.Price
                        @if (!string.IsNullOrEmpty(listing.PriceSuffix))
                        {
                            <span> @listing.PriceSuffix</span>
                        }
                    </div>
                    <div class="wo-card-meta">
                        <div class="wo-user-avatar" style="background: @listing.AvatarBg; color: @listing.AvatarColor;">
                            @listing.UserInitials
                        </div>
                        <span class="wo-card-user">@listing.Username</span>
                        <span class="wo-card-loc">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Style="font-size: 10px;" />
                            @listing.Location
                        </span>
                    </div>
                </div>
            </div>
        </MudItem>
    }
</MudGrid>

@code {
    private string _activeFilter = "Alle";
    private string _sortBy = "Neueste zuerst";

    private readonly string[] _filters = { "Alle", "Neu", "In der Nähe", "Preisalarm" };

    private record CategoryItem(string Key, string Emoji, string Label, int Count);

    private readonly List<CategoryItem> _categories = new()
    {
        new("buecher",    "📚", "Bücher",       214),
        new("elektronik", "💻", "Elektronik",   183),
        new("wohnen",     "🏠", "WG & Wohnen",   91),
        new("nachhilfe",  "🎓", "Nachhilfe",     76),
        new("sport",      "⚽", "Sport",         142),
        new("sonstiges",  "🎯", "Sonstiges",     141),
    };

    private class Listing
    {
        public string Title { get; set; } = "";
        public string Category { get; set; } = "";
        public string FilterTag { get; set; } = "Alle";
        public string Emoji { get; set; } = "";
        public string ThumbClass { get; set; } = "";
        public string Price { get; set; } = "";
        public string PriceSuffix { get; set; } = "";
        public string? Badge { get; set; }
        public string BadgeClass { get; set; } = "";
        public string Username { get; set; } = "";
        public string UserInitials { get; set; } = "";
        public string Location { get; set; } = "";
        public string AvatarBg { get; set; } = "#EEF2FF";
        public string AvatarColor { get; set; } = "#4F46E5";
        public bool Saved { get; set; }
        public int PriceRaw { get; set; }
    }

    private List<Listing> _listings = new()
    {
        new Listing { Title="Analysis I – Forster, 12. Auflage", Category="Bücher & Skripte", FilterTag="Neu",
            Emoji="📚", ThumbClass="thumb-books", Price="8 €", PriceSuffix=" VB",
            Badge="Neu", BadgeClass="badge-new",
            Username="marie_kit", UserInitials="MK", Location="Südstadt", Saved=true, PriceRaw=8 },

        new Listing { Title="MacBook Air M2 – wie neu", Category="Elektronik", FilterTag="Alle",
            Emoji="💻", ThumbClass="thumb-tech", Price="880 €", PriceSuffix=" VB",
            Username="tim.freiburg", UserInitials="TF", Location="Innenstadt",
            AvatarBg="#F0FDF4", AvatarColor="#15803D", PriceRaw=880 },

        new Listing { Title="12m² Zimmer, WG Nähe KIT", Category="WG & Wohnen", FilterTag="In der Nähe",
            Emoji="🏠", ThumbClass="thumb-home", Price="390 €", PriceSuffix=" / Monat",
            Badge="WG", BadgeClass="badge-wg",
            Username="sara_riedel", UserInitials="SR", Location="Oststadt",
            AvatarBg="#FFF7ED", AvatarColor="#C2410C", PriceRaw=390 },

        new Listing { Title="Mathe / Lineare Algebra – Nachhilfe", Category="Nachhilfe", FilterTag="Alle",
            Emoji="📐", ThumbClass="thumb-study", Price="20 €", PriceSuffix=" / Std",
            Username="jan.lehmann", UserInitials="JL", Location="Nordstadt", PriceRaw=20 },

        new Listing { Title="Stadtrad 28\" – Kette neu", Category="Sport & Freizeit", FilterTag="Preisalarm",
            Emoji="🚲", ThumbClass="thumb-sport", Price="65 €",
            Badge="Preistipp", BadgeClass="badge-deal",
            Username="paula.w", UserInitials="PW", Location="Weststadt",
            AvatarBg="#FDF4FF", AvatarColor="#7E22CE", PriceRaw=65 },

        new Listing { Title="Sony WH-1000XM4 Kopfhörer", Category="Elektronik", FilterTag="Alle",
            Emoji="🎧", ThumbClass="thumb-misc", Price="155 €", PriceSuffix=" VB",
            Username="b.hofmann", UserInitials="BH", Location="Durlach",
            AvatarBg="#F0F9FF", AvatarColor="#0369A1", PriceRaw=155 },

        new Listing { Title="Thermodynamik – Skript WS23/24", Category="Bücher & Skripte", FilterTag="Neu",
            Emoji="🗒️", ThumbClass="thumb-books", Price="Gratis",
            Badge="Neu", BadgeClass="badge-new",
            Username="alex_kit23", UserInitials="AK", Location="Südstadt", PriceRaw=0 },

        new Listing { Title="IKEA Schreibtisch LINNMON 120×60", Category="Sonstiges", FilterTag="Alle",
            Emoji="🛏️", ThumbClass="thumb-misc", Price="35 €",
            Username="f.mueller", UserInitials="FM", Location="Innenstadt",
            AvatarBg="#F0F9FF", AvatarColor="#0369A1", PriceRaw=35 },
    };

    private IEnumerable<Listing> FilteredListings => _activeFilter == "Alle"
        ? SortedListings
        : SortedListings.Where(l => l.FilterTag == _activeFilter);

    private IEnumerable<Listing> SortedListings => _sortBy switch
    {
        "Preis ↑" => _listings.OrderBy(l => l.PriceRaw),
        "Preis ↓" => _listings.OrderByDescending(l => l.PriceRaw),
        _ => _listings.AsEnumerable(),
    };

    private void SetFilter(string filter) => _activeFilter = filter;

    private void FilterByCategory(string key)
    {
        // Navigation to category page or filter — erweiterbar
    }

    private void ToggleSaved(Listing listing) => listing.Saved = !listing.Saved;
}

